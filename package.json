{
  "name": "larkcc",
  "version": "0.1.8",
  "description": "Claude Code in Feishu/Lark - AI coding assistant bot",
  "author": "sujie <13156660820@163.com>",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suj1e/larkcc.git"
  },
  "bugs": {
    "url": "https://github.com/suj1e/larkcc/issues"
  },
  "homepage": "https://github.com/suj1e/larkcc#readme",
  "keywords": [
    "ai",
    "coding-assistant",
    "claude",
    "feishu",
    "lark",
    "bot",
    "chatbot",
    "claude-code"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "larkcc": "./bin/larkcc"
  },
  "scripts": {
    "prebuild": "node scripts/generate-version.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/commands && cp src/commands/default-prompts.yml dist/commands/",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@larksuiteoapi/node-sdk": "^1",
    "chalk": "^5",
    "commander": "^12",
    "js-yaml": "^4",
    "ora": "^8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^22",
    "semver": "^7.7.4",
    "tsx": "^4",
    "typescript": "^5"
  }
}
